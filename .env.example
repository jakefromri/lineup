# This is a reference only — `bash setup.sh` writes the real .env files for you.
# Each app gets its own .env: apps/api/.env, apps/web/.env, apps/admin/.env

# ─── apps/api/.env ──────────────────────────────────────────────────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# WEB_URL=http://localhost:5173      # parent app — used for join links + CORS
# ADMIN_URL=http://localhost:5174    # manager/superadmin app — used for invite links + CORS
# PORT=3000

# ─── apps/web/.env (parent-facing app) ─────────────────────────────────────
# Parents use pat_ access tokens stored in localStorage, not Supabase Auth —
# this app only needs to know where the API is.
# VITE_API_URL=http://localhost:3000

# ─── apps/admin/.env (manager/superadmin app) ──────────────────────────────
# Managers and superadmins authenticate via Supabase Auth.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
# VITE_API_URL=http://localhost:3000
# VITE_WEB_URL=http://localhost:5173
